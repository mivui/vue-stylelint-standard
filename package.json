{
  "name": "vue-stylelint-standard",
  "version": "17.0.3",
  "description": "quickly start stylelint in vue",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js"
  },
  "dependencies": {
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.0",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript-eslint-standard": "^10.1.0",
    "vitest": "^4.1.1"
  },
  "author": "mivui",
  "license": "MIT",
  "keywords": [
    "vue",
    "stylelint",
    "prettier"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mivui/vue-stylelint-standard.git"
  },
  "bugs": {
    "url": "https://github.com/mivui/vue-stylelint-standard/issues"
  },
  "homepage": "https://github.com/mivui/vue-stylelint-standard#readme"
}
